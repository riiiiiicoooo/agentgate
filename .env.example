# Server Configuration
PORT=8000
ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/agentgate

# JWT & Security
JWT_SECRET=YOUR_JWT_SECRET_KEY_CHANGE_IN_PRODUCTION
JWT_EXPIRATION_MINUTES=60

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# Secrets Backend (vault, aws, 1password, env)
SECRETS_BACKEND=env

# Vault Configuration
VAULT_URL=http://localhost:8200
VAULT_TOKEN=YOUR_VAULT_TOKEN
VAULT_MOUNT_PATH=secret

# AWS Configuration
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
AWS_REGION=us-east-1

# 1Password Configuration
OP_SERVICE_ACCOUNT_TOKEN=YOUR_1PASSWORD_TOKEN

# LLM Configuration
LLM_TOKEN_BUDGET_DEFAULT=100000
LLM_TOKEN_BUDGET_HOURLY=10000
