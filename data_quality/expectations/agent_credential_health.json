{
  "data_asset_type": "Table",
  "expectation_suite_name": "agent_credential_health",
  "expectations": [
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {
        "min_value": 1,
        "max_value": 10000
      },
      "meta": {
        "description": "Should have at least 1 agent, not more than 10k"
      }
    },
    {
      "expectation_type": "expect_table_columns_to_match_ordered_list",
      "kwargs": {
        "column_list": [
          "agent_id",
          "agent_name",
          "agent_type",
          "client_id",
          "client_secret",
          "api_key",
          "created_at",
          "last_rotated",
          "rotation_interval_days",
          "credential_rotation_required",
          "status",
          "updated_at"
        ]
      },
      "meta": {
        "description": "Agents table must have all required columns"
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "agent_id"
      },
      "meta": {
        "description": "agent_id is required"
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "agent_name"
      },
      "meta": {
        "description": "agent_name is required"
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "created_at"
      },
      "meta": {
        "description": "created_at is required"
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "status"
      },
      "meta": {
        "description": "status is required"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "status",
        "value_set": ["active", "inactive", "suspended", "revoked"]
      },
      "meta": {
        "description": "status must be one of the allowed values"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "agent_type",
        "value_set": ["copilot", "editor", "ide", "pipeline", "custom", "admin"]
      },
      "meta": {
        "description": "agent_type must be one of the known types"
      }
    },
    {
      "expectation_type": "expect_column_values_to_match_regex",
      "kwargs": {
        "column": "agent_id",
        "regex": "^[a-z0-9-]+$"
      },
      "meta": {
        "description": "agent_id must be lowercase alphanumeric with hyphens"
      }
    },
    {
      "expectation_type": "expect_column_value_lengths_to_be_between",
      "kwargs": {
        "column": "agent_id",
        "min_value": 5,
        "max_value": 100
      },
      "meta": {
        "description": "agent_id must be reasonable length"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_type_list",
      "kwargs": {
        "column": "created_at",
        "type_list": ["TIMESTAMP", "DATETIME", "DATE"]
      },
      "meta": {
        "description": "created_at must be timestamp type"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_type_list",
      "kwargs": {
        "column": "last_rotated",
        "type_list": ["TIMESTAMP", "DATETIME", "DATE"]
      },
      "meta": {
        "description": "last_rotated must be timestamp type"
      }
    },
    {
      "expectation_type": "expect_column_proportion_of_unique_values_to_be_between",
      "kwargs": {
        "column": "agent_id",
        "min_value": 0.99,
        "max_value": 1.0
      },
      "meta": {
        "description": "agent_id should be nearly unique"
      }
    },
    {
      "expectation_type": "expect_column_distinct_values_to_be_greater_than",
      "kwargs": {
        "column": "agent_type",
        "value": 1
      },
      "meta": {
        "description": "Should have multiple agent types"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "rotation_interval_days",
        "min_value": 1,
        "max_value": 365
      },
      "meta": {
        "description": "Rotation interval should be 1-365 days"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_type_list",
      "kwargs": {
        "column": "rotation_interval_days",
        "type_list": ["INTEGER", "INT", "BIGINT", "SMALLINT"]
      },
      "meta": {
        "description": "rotation_interval_days must be integer"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_type_list",
      "kwargs": {
        "column": "credential_rotation_required",
        "type_list": ["BOOLEAN", "BOOL"]
      },
      "meta": {
        "description": "credential_rotation_required must be boolean"
      }
    },
    {
      "expectation_type": "expect_select_column_values_to_be_unique_within_record",
      "kwargs": {
        "column_list": ["client_id", "api_key"],
        "ignore_row_if": "any_value_is_null"
      },
      "meta": {
        "description": "client_id and api_key should be unique per agent"
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_match_regex",
      "kwargs": {
        "column": "client_secret",
        "regex": "YOUR_.*"
      },
      "meta": {
        "description": "Secrets should not contain placeholder strings"
      }
    },
    {
      "expectation_type": "expect_column_value_lengths_to_be_between",
      "kwargs": {
        "column": "client_secret",
        "min_value": 32,
        "max_value": 256
      },
      "meta": {
        "description": "Secrets should be reasonable length"
      }
    },
    {
      "expectation_type": "expect_column_stl_duration_ms_to_be_less_than",
      "kwargs": {
        "column": "last_rotated",
        "days": 90
      },
      "meta": {
        "description": "Credentials should have been rotated within 90 days"
      }
    },
    {
      "expectation_type": "expect_multicolumn_values_to_be_unique",
      "kwargs": {
        "column_list": ["agent_id"]
      },
      "meta": {
        "description": "agent_id must be globally unique"
      }
    },
    {
      "expectation_type": "expect_table_columns_to_contain_set",
      "kwargs": {
        "column_set": ["agent_id", "status", "created_at"]
      },
      "meta": {
        "description": "Critical columns must be present"
      }
    }
  ],
  "meta": {
    "great_expectations_version": "0.15.50",
    "created_datetime": "2026-03-04T10:00:00Z",
    "modified_datetime": "2026-03-04T10:00:00Z",
    "description": "Data quality expectations for agent credential health",
    "alert_conditions": {
      "expired_credentials": "agents where last_rotated > rotation_interval_days",
      "unhealthy_agents": "agents with status not in ['active', 'inactive']",
      "secret_format_violations": "agents where client_secret doesn't meet length requirements"
    }
  }
}
