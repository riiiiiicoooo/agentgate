{
  "name": "agentgate",
  "version": "1.0.0",
  "description": "TypeScript SDK for AgentGate - AI Agent Authentication & Authorization Gateway",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "prepublishOnly": "npm run build && npm run test"
